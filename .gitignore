# Vite cache
.vite/

# Internal notes
internal/

# Shadow .js emissions next to TypeScript sources — Vite resolves .js before .ts,
# so any stray compiled .js will silently override the real source.
docs/src/**/*.js
src/**/*.js
devices/src/**/*.js

# One-off scripts at repo root (anchor so nested scripts/ dirs aren't swept up)
/scripts/

# Local dev
start-dev.sh
email-signature.html
